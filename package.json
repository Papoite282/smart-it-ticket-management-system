{
  "name": "smart-it-ticket-management-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "ServiceNow-inspired Smart IT Ticket Management System built with React, TypeScript, Zustand, React Query, Express and SQLite.",
  "scripts": {
    "dev": "vite",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start:server": "node dist-server/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:server": "vitest run server/app.test.ts",
    "check": "npm run test:run && npm run build && npm run build:server"
  },
  "keywords": [
    "servicenow",
    "it-ticket-management",
    "react",
    "typescript",
    "zustand",
    "react-query",
    "express",
    "sqlite",
    "kanban",
    "rbac"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@tanstack/react-query": "^5.59.16",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "sql.js": "^1.14.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.11",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
